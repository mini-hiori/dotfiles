# aws-sso-config.local.sh.example
#
# このファイルを aws-sso-config.local.sh にコピーして自分の環境用に編集する。
# aws-sso-config.local.sh は .gitignore で除外されているため commit されない。
#
#   cp aws-sso-config.local.sh.example aws-sso-config.local.sh
#   $EDITOR aws-sso-config.local.sh

# 利用するアカウント一覧。
# 形式: "ACCOUNT_ID:ROLE_NAME:ENV_NAME:DESCRIPTION"
#   ACCOUNT_ID  : 12 桁の AWS アカウント ID
#   ROLE_NAME   : SSO で assume するロール名 (例: AdministratorAccess, sre, ReadOnly 等)
#   ENV_NAME    : profile 名のプレフィックス (任意の識別子)
#   DESCRIPTION : 選択メニューに表示する説明
# 作成される profile 名は "${ENV_NAME}-${ROLE_NAME}" となる。
ACCOUNTS=(
    # "123456789012:AdministratorAccess:my-org-prod:my-org-prod"
    # "210987654321:ReadOnly:my-org-staging:my-org-staging"
)

# IAM Identity Center の Start URL
SSO_START_URL=""  # 例: "https://YOUR-ORG.awsapps.com/start"

# region のデフォルトは aws-sso-login.sh 側で ap-northeast-1。
# 別の region を使う場合のみコメントアウトを外して上書き
# SSO_REGION="us-east-1"
